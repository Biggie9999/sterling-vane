# 🏛️ Sterling Vane: Environment Configuration Template
# Duplicate this file to '.env' and fill in your unique production credentials.

# --- INFRASTRUCTURE: MULTI-REGION PERSISTENCE ---
# Use the Supabase 'Session Pooler' (6543) for serverless stability or 'Direct' (5432).
DATABASE_URL="postgresql://user:pass@db.xxxx.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@db.xxxx.supabase.co:5432/postgres"

# --- AUTHENTICATION: SOVEREIGN SESSIONS ---
# Set NEXTAUTH_URL to http://localhost:3000 (Local) or your Vercel URL (Production).
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_generated_secret_here"

# --- PARTNER CHANNELS: GOOGLE OAUTH ---
# Required for the 'Partner Manifestation' flow.
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="xxxx_secret_xxxx"

# --- TRANSACTIONAL: STRIPE TERMINAL ---
# Required for 'Capital Deployment' and booking cycles.
STRIPE_SECRET_KEY="sk_test_xxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxx"

# --- COMMUNICATIONS: RESEND (EMAIL) ---
RESEND_API_KEY="re_xxxx"
EMAIL_FROM="noreply@sterlingvane.com"

# --- ANALYTICS & VISUALS: MAPBOX ---
NEXT_PUBLIC_MAPBOX_TOKEN="pk.xxxx"

# --- LIVE ASSET FEEDS: RAPIDAPI ---
# Powering real-time market data across the 64-collection.
RAPIDAPI_KEY="3f0d001856msh8482a346cea4055p117622jsnfd8d7c5cf5a3"
